[
  {
    "table": "fact_claims",
    "description": "Contains one row per healthcare claim. This is the main fact table used for financial and operational analytics.\n",
    "grain": "one row per claim",
    "pii": false,
    "columns": [
      {
        "name": "claim_id",
        "type": "BIGINT",
        "description": "Unique identifier for each claim",
        "pii": false
      },
      {
        "name": "member_id",
        "type": "BIGINT",
        "description": "Identifier for the member who received the service",
        "pii": false
      },
      {
        "name": "provider_id",
        "type": "BIGINT",
        "description": "Identifier for the healthcare provider",
        "pii": false
      },
      {
        "name": "service_date",
        "type": "TIMESTAMP_NS",
        "description": "Date when the healthcare service was performed",
        "pii": false
      },
      {
        "name": "paid_amount",
        "type": "DOUBLE",
        "description": "Amount paid for the claim",
        "pii": false
      },
      {
        "name": "denial_flag",
        "type": "BIGINT",
        "description": "Indicates whether the claim was denied (1) or approved (0)",
        "pii": false
      }
    ]
  },
